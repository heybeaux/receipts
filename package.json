{
  "name": "@beaux-riel/receipts",
  "version": "0.1.0",
  "description": "Verifiable proof-of-work for AI teams.",
  "main": "src/cli.js",
  "bin": {
    "receipts": "bin/receipts.js"
  },
  "files": [
    "bin/",
    "src/",
    "openclaw/",
    "schemas/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run openspec:validate && npm run test:unit && npm run cli:smoke",
    "test:unit": "node test/unit.js",
    "cli": "node bin/receipts.js",
    "cli:smoke": "node test/smoke.js",
    "openspec:list": "openspec list",
    "openspec:show": "openspec show define-receipts-v0",
    "openspec:validate": "openspec validate define-receipts-v0 && openspec validate --all",
    "lint": "node scripts/lint-syntax.js",
    "build": "npm pack --dry-run --json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@fission-ai/openspec": "^1.4.1"
  },
  "openclaw": {
    "extensions": [
      "./openclaw/plugin.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.18",
      "minGatewayVersion": "2026.5.18"
    },
    "build": {
      "openclawVersion": "2026.5.18",
      "pluginSdkVersion": "2026.5.18"
    }
  }
}
